"use strict";

// Anti-Flash Blocker - MUST BE FIRST
// Immediately inject style to hide everything before Krunker loads
try {
    const css = `
        html, body { background: #000 !important; overflow: hidden !important; }
        body * { display: none !important; opacity: 0 !important; visibility: hidden !important; }
        #water-loading-overlay, #loading-overlay { display: flex !important; opacity: 1 !important; visibility: visible !important; }
    `;
    if (document.head) {
        const style = document.createElement('style');
        style.id = 'water-flash-blocker';
        style.textContent = css;
        document.head.appendChild(style);
    } else {
        const style = document.createElement('style');
        style.id = 'water-flash-blocker';
        style.textContent = css;
        document.documentElement.appendChild(style);
    }
} catch (e) { }

