{
    "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
    "appId": "com.ghosty.water",
    "productName": "Water",
    "copyright": "Copyright © 2026 Ghosty",
    "icon": "assets/img/logo.png",
    "files": [
        "js/**/*",
        "assets/**/*",
        "buildinfo.json"
    ],
    "win": {
        "artifactName": "Water-${version}.${ext}",
        "target": [
            {
                "target": "nsis",
                "arch": "x64"
            },
            {
                "target": "nsis",
                "arch": "ia32"
            },
            {
                "target": "portable",
                "arch": "x64"
            },
            {
                "target": "portable",
                "arch": "ia32"
            }
        ]
    },
    "linux": {
        "artifactName": "${name}-${os}-portable-${version}-${arch}.${ext}",
        "category": "Game",
        "target": [
            {
                "target": "AppImage",
                "arch": "x64"
            },
            {
                "target": "AppImage",
                "arch": "ia32"
            }
        ]
    },
    "nsis": {
        "artifactName": "Water-Setup-${version}.${ext}",
        "oneClick": true,
        "perMachine": false,
        "allowToChangeInstallationDirectory": false
    }
}