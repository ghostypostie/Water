{
    "appId": "com.ghosty.water",
    "productName": "Water",
    "copyright": "Copyright © 2026 Ghosty",
    "icon": "assets/img/logo.png",
    "electronVersion": "12.0.0-nightly.20201116",
    "files": [
        "js/**/*",
        "assets/**/*",
        "buildinfo.json"
    ],
    "extraMetadata": {
        "main": "js/launch.js"
    },
    "publish": {
        "provider": "github",
        "owner": "ghostypostie",
        "repo": "Water",
        "releaseType": "release"
    },
    "win": {
        "artifactName": "Water.${ext}",
        "target": [
            {
                "target": "nsis",
                "arch": "x64"
            }
        ],
        "publish": {
            "provider": "github",
            "owner": "ghostypostie",
            "repo": "Water"
        }
    },
    "nsis": {
        "artifactName": "Water.${ext}",
        "oneClick": true,
        "perMachine": false,
        "allowToChangeInstallationDirectory": false,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "Water"
    },
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": false
