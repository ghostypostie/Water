{
  "name": "Water",
  "version": "1.1.3",
  "description": "Fresh Water",
  "author": "Ghosty",
  "main": "js/launch.js",
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/ws": "^8.5.10",
    "electron": "npm:electron-nightly@12.0.0-nightly.20201116",
    "electron-builder": "^26.8.1",
    "shx": "^0.4.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "discord-rpc-revamp": "^2.0.3",
    "dotenv": "^17.4.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "ws": "^8.16.0"
  },
  "scripts": {
    "clean:win": "rmdir /s /q js",
    "clean:linux": "rm -rf js",
    "transpile": "npx tsc",
    "start": "npm run transpile && npx electron .",
    "build": "npm run transpile && npx electron-builder",
    "build:win": "npm run transpile && npx electron-builder --win",
    "build:mac": "npm run transpile && npx electron-builder --mac",
    "build:linux": "npm run transpile && npx electron-builder --linux",
    "build:all": "npm run transpile && npx electron-builder -wml",
    "release": "npm run transpile && npx electron-builder --publish always"
  }
}
